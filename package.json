    "dotenv": "^16.6.1",
    "i18n": "^0.15.3",
    "nanoid": "^3.3.11",
    "node-cron": "^3.0.3",
    "satori": "^0.25.0",
    "satori-html": "0.3.1",
    "sequelize": "^6.37.8",
    "sqlite3": "^5.1.7"
  },
  "overrides": {
    "@discordjs/builders": "1.11.2"
  },
  "devDependencies": {
    "@types/i18n": "^0.13.12",
    "@types/node": "^22.19.15",
    "@types/node-cron": "^3.0.11",
    "@types/sequelize": "^4.28.20",
    "bun-types": "^1.3.10",
    "prettier": "^3.8.1",
    "typescript": "5.5.4"
  }
