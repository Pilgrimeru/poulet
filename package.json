{
  "name": "poulet-bot",
  "version": "1.0.0",
  "description": "Bot de moderation pour Débat Public.",
  "main": "./src/index.ts",
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": ">=1.3.10"
  },
  "scripts": {
    "start": "bun run ./src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test --pass-with-no-tests",
    "prod": "bun run ./src/index.ts",
    "dashboard": "bun run ./scripts/dashboard.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",

    "chrono-node": "^2.9.0",
    "discord.js": "14.25.1",
    "dotenv": "^17.3.1",
    "i18n": "^0.15.3",
    "nanoid": "^5.1.7",
    "node-cron": "^4.2.1",
    "satori": "^0.25.0",
    "satori-html": "0.3.1",
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1"
  },
  "overrides": {
    "@discordjs/builders": "1.11.2"
  },
  "devDependencies": {
    "@types/i18n": "^0.13.12",
    "@types/bun": "^1.3.10",
    "@types/node-cron": "^3.0.11",
    "@types/sequelize": "^4.28.20",
    "bun-types": "^1.3.10",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
