# ==========================================
# Configuration du Bot & Dashboard Poulet
# ==========================================
# Copiez ce fichier en config.env et remplissez les valeurs

# --- Discord Bot ---
TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Authentification Dashboard ---
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback
DASHBOARD_SESSION_SECRET=change-me-to-a-random-string
DASHBOARD_INTERNAL_API_SECRET=change-me-to-another-random-string

# --- API OpenRouter (IA de modération) ---
OPENROUTER_API_KEY=
AI_PRIMARY_MODEL=openai/gpt-oss-120b:free
AI_FALLBACK_MODEL=openai/gpt-oss-120b:floor

# --- Configuration du Bot ---
API_URL=http://localhost:3000/api
LOCALE=fr
MAIN_COLOR=#69ADC7
AUTO_DELETE=true
MESSAGE_RETENTION_DAYS=7
ALLOW_DUPLICATE_SANCTIONED_MESSAGE_REPORTS=false

# --- Cache IA ---
AI_LLM_CACHE_PATH=./cache/langchain-llm-cache.sqlite
AI_LLM_CACHE_TTL_MS=604800000

# --- Fuseau horaire ---
SOURCE_REPORT_TIMEZONE=Europe/Paris

# --- Bases de données (chemins par défaut pour Docker) ---
# DATABASE_PATH=/app/database/database.sqlite
# ATTACHMENTS_PATH=/app/database/attachments
